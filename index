      '<div class="stit mb6">'+t('players')+'</div>'+
      G.players.map(p=>'<div style="display:flex;align-items:center;justify-content:space-between;padding:9px 13px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);margin-bottom:4px;border-radius:2px">'+
        '<span class="cin" style="font-size:.86rem;'+(p.alive?'':'opacity:.3;text-decoration:line-through')+'">'+e(p.name)+'</span>'+
