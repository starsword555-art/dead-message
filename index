vote(){
  const alive=alivePl(),sel=G.voteTarget;
  return '<div class="scr" style="background:var(--bg)">'+topbar(t('voteBtn').replace(' →',''))+
    '<div class="p16 f fc g10 afd">'+
      '<div class="cin mt10" style="font-size:1rem;font-weight:700">'+t('voteTitle')+'</div>'+
      '<div class="gdiv" style="margin:0 0 4px"></div>'+
      '<div class="cx" style="font-size:.8rem;margin-bottom:4px">'+t('voteInstr')+' <strong>'+t('skipRound')+'</strong></div>'+
      alive.map(p=>{const pi=G.players.indexOf(p),s=sel===pi;return '<div class="pi'+(s?' sel':'')+'" data-a="vpick" data-v="'+pi+'"><div><div class="pn">'+e(p.name)+'</div></div>'+(s?'<span class="ch chr">'+t('selCheck')+'</span>':'')+'</div>';}).join('')+
      '<div class="pi'+(sel===-99?' sk':'')+'" data-a="vskip"><div><div class="pn" style="color:#5ad080">'+t('skipRound')+'</div><div class="pj">'+t('noExec')+'</div></div>'+(sel===-99?'<span class="ch cho">'+t('selCheck')+'</span>':'')+'</div>'+
      ((sel!==undefined&&sel!==null&&sel!==-1)?'<button class="btn bb bfw blg mt8" data-a="vconf">'+t('confirm')+'</button>':'<button class="btn bs bfw blg mt8" style="opacity:.35;pointer-events:none">'+t('pickFirst')+'</button>')+
    '</div></div>';
},
gameover(){
  const tw=G.gameResult==='town',m=G.players[G.murdererIdx],d=G.players[G.detectiveIdx];
  return '<div class="scr" style="background:var(--bg)">'+topbar(t('gameOver'))+
    '<div class="p16 f fc g14 afd">'+
      '<div class="tc mt16"><div style="font-size:3rem;margin-bottom:10px">'+(tw?'🏆':'💀')+'</div>'+
        '<div class="cin" style="font-size:1.8rem;font-weight:900;'+(tw?'color:#5ad080':'color:var(--blood)')+'">'+t(tw?'citizenWins':'murdererWins')+'</div></div>'+
      '<div class="'+(tw?'cxg':'cxr')+' cx" style="font-size:.85rem;text-align:center">'+t(tw?'citizenWinMsg':'murdererWinMsg')+'</div>'+
      '<div class="stit mb8">'+t('revealRoles')+'</div>'+
      G.players.map(p=>{const im=G.players.indexOf(p)===G.murdererIdx,id=G.players.indexOf(p)===G.detectiveIdx,ri=roleInfo(p.role);
        return '<div style="display:flex;align-items:center;justify-content:space-between;padding:11px 14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);margin-bottom:5px;border-radius:2px">'+
          '<div style="display:flex;align-items:center;gap:8px"><span style="font-size:1.2rem">'+ri.ico+'</span><span class="cin" style="font-size:.88rem;'+(p.alive?'':'opacity:.38;text-decoration:line-through')+'">'+e(p.name)+'</span></div>'+
          '<span class="ch '+(im?'chr':id?'chb':'cho')+'">'+ri.tt+'</span></div>';}).join('')+
      (G.history.length?'<div class="stit mt8 mb8">'+t('murderLog')+'</div>'+G.history.map((h,i)=>'<div class="cx" style="font-size:.76rem;margin-bottom:5px"><strong>'+t('nightLabel')+' '+(i+1)+'</strong> — '+e(h.victimName)+'<br>'+h.shownCards.map(ci=>EVID[ci].e+' '+e(EN(EVID[ci]))).join(' · ')+'</div>').join(''):'')+''+
      '<div class="f g8 mt12">'+
        '<button class="btn bs grow" data-a="go-title">'+t('playAgain')+'</button>'+
        '<button class="btn bb" style="gap:4px" data-a="go-donate">Donate 🤪</button>'+
      '</div>'+
    '</div></div>';
},
donate(){
  return '<div class="scr scc f fc" style="background:var(--bg)">'+
    '<div class="p20 f fc ac g16 asc" style="max-width:380px;margin:0 auto;text-align:center">'+
      '<div style="font-size:2.6rem">🤪</div>'+
      '<div class="cin" style="font-size:1.3rem;font-weight:700;color:var(--gold)">'+t('donateMsg')+'</div>'+
      '<div style="background:#fff;border-radius:12px;padding:14px;box-shadow:0 0 30px rgba(201,169,110,.22);display:inline-block">'+
        '<img src="'+QR+'" style="width:260px;max-width:85vw;display:block;border-radius:4px" alt="QR Donate">'+
      '</div>'+
      '<p style="color:var(--dim);font-size:.86rem;line-height:1.65;max-width:280px">'+
        (G.lang==='en'?'Scan QR to donate — thank you for your support! 🙏':'สแกน QR เพื่อโอนเงินบริจาค ขอบคุณที่สนับสนุนครับ 🙏')+
      '</p>'+
      '<button class="btn bb blg" style="min-width:200px" data-a="go-title">'+t('playAgain')+'</button>'+
