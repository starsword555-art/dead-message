/* ══ AUDIO ══ */
let _ac=null;
function ac(){
  try{if(!_ac)_ac=new(window.AudioContext||window.webkitAudioContext)();}catch(e){return null;}
  if(_ac&&_ac.state==='suspended')_ac.resume();
  return _ac;
}
function _osc(ctx,type,f,vol,t0,dur){
  try{
    const o=ctx.createOscillator(),g=ctx.createGain();
    o.type=type;o.frequency.value=f;o.connect(g);g.connect(ctx.destination);
    g.gain.setValueAtTime(0,t0);g.gain.linearRampToValueAtTime(vol,t0+.02);
    g.gain.exponentialRampToValueAtTime(.0001,t0+dur);
    o.start(t0);o.stop(t0+dur+.05);
  }catch(e){}
}
function _noise(ctx,vol,t0,dur,ff){
  try{
    const b=ctx.createBuffer(1,ctx.sampleRate*dur,ctx.sampleRate);
    const d=b.getChannelData(0);
    for(let i=0;i<d.length;i++) d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,1.5);
    const s=ctx.createBufferSource(),f=ctx.createBiquadFilter(),g=ctx.createGain();
    s.buffer=b;f.type='bandpass';f.frequency.value=ff;f.Q.value=.4;g.gain.value=vol;
    s.connect(f);f.connect(g);g.connect(ctx.destination);s.start(t0);
  }catch(e){}
}
function snd(type){
  const ctx=ac();if(!ctx)return;
  const t=ctx.currentTime;
  try{({
    stab:()=>{_noise(ctx,.7,t,.25,3000);_osc(ctx,'sawtooth',90,.4,t,.35);_osc(ctx,'sine',60,.3,t+.05,.4);},
    death:()=>{[350,280,200,140,90].forEach((f,i)=>_osc(ctx,'sine',f,.3,t+i*.22,.6));},
    tick:()=>{_osc(ctx,'square',500+Math.random()*500,.09,t,.05);},
    settle:()=>{[330,440,550,660,880].forEach((f,i)=>_osc(ctx,'sine',f,.2,t+i*.09,.45));},
    reveal:()=>{
      for(let i=0;i<10;i++) _osc(ctx,'triangle',160,.14,t+i*.04,.04);
      _osc(ctx,'sawtooth',65,.5,t+.44,.8);_noise(ctx,.45,t+.44,.4,600);
    },
    night:()=>{
      const o=ctx.createOscillator(),g=ctx.createGain();
      o.type='sine';o.frequency.setValueAtTime(180,t);o.frequency.exponentialRampToValueAtTime(65,t+2);
      o.connect(g);g.connect(ctx.destination);
      g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(.3,t+.3);g.gain.exponentialRampToValueAtTime(.001,t+2.2);
      o.start(t);o.stop(t+2.3);
    },
    dawn:()=>{[200,260,330,400,520].forEach((f,i)=>_osc(ctx,'sine',f,.2,t+i*.15,.65));},
    execute:()=>{_noise(ctx,.75,t,.45,350);_osc(ctx,'square',50,.5,t,.55);_osc(ctx,'sine',80,.3,t+.1,.4);},
    winCitizen:()=>{[262,330,392,523,659,784].forEach((f,i)=>_osc(ctx,'sine',f,.28,t+i*.11,.55));},
    winMurderer:()=>{[180,150,120,90,65].forEach((f,i)=>_osc(ctx,'sawtooth',f,.22,t+i*.2,.7));},
    roleReveal:()=>{_osc(ctx,'sine',440,.3,t,.18);_osc(ctx,'sine',550,.25,t+.12,.22);_osc(ctx,'sine',660,.2,t+.22,.18);},
    click:()=>{_osc(ctx,'sine',800,.06,t,.06);}
  })[type]?.();}catch(e){}
}

