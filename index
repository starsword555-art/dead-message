:root{--bg:#0d0408;--pan:#1a0a10;--parch:#f5ead5;--crim:#8b1a1a;--blood:#c02020;--gold:#c9a96e;--dim:#8a6a5a;--lt:#f4ead5;}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{min-height:100%;background:#000;}
body{font-family:'Sarabun',sans-serif;background:var(--bg);color:var(--lt);min-height:100vh;overflow-x:hidden;}
#app{min-height:100vh;max-width:430px;margin:0 auto;position:relative;background:var(--bg);}
#cL,#cR{position:fixed;top:0;bottom:0;width:50%;background:var(--bg);z-index:50;transition:transform 1.3s cubic-bezier(.77,0,.175,1);}
#cL{left:0;}#cR{right:0;}
#cL.op{transform:translateX(-100%);}#cR.op{transform:translateX(100%);}
.cin{font-family:'Cinzel',serif;}
h1.xl{font-family:'Cinzel',serif;font-size:clamp(2.6rem,12vw,5.5rem);font-weight:900;letter-spacing:.06em;line-height:1.1;text-shadow:0 0 80px rgba(192,32,32,.7);}
.tagline{font-family:'Cinzel',serif;font-size:.72rem;letter-spacing:.44em;color:var(--blood);text-transform:uppercase;}
.stit{font-family:'Cinzel',serif;font-size:.7rem;letter-spacing:.22em;color:var(--dim);text-transform:uppercase;}
.scr{min-height:100vh;display:flex;flex-direction:column;}
.scc{align-items:center;justify-content:center;text-align:center;}
.p16{padding:16px;}.p20{padding:20px;}
.g8{gap:8px;}.g10{gap:10px;}.g12{gap:12px;}.g14{gap:14px;}.g16{gap:16px;}
.f{display:flex;}.fc{flex-direction:column;}.fw{flex-wrap:wrap;}.ac{align-items:center;}.jc{justify-content:center;}.jsb{justify-content:space-between;}
.tc{text-align:center;}.grow{flex:1;}.w100{width:100%;}
.mt8{margin-top:8px;}.mt12{margin-top:12px;}.mt16{margin-top:16px;}.mt20{margin-top:20px;}.mt28{margin-top:28px;}
.mb8{margin-bottom:8px;}.mb12{margin-bottom:12px;}
.tb{position:sticky;top:0;z-index:10;background:rgba(13,4,8,.95);border-bottom:1px solid rgba(201,169,110,.12);backdrop-filter:blur(6px);padding:10px 14px;display:flex;align-items:center;justify-content:space-between;}
.tb-t{font-family:'Cinzel',serif;font-size:.66rem;letter-spacing:.3em;color:var(--gold);}
.tb-r{font-family:'Cinzel',serif;font-size:.66rem;color:var(--dim);}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;font-family:'Cinzel',serif;font-size:.76rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;min-height:50px;padding:11px 20px;border:none;cursor:pointer;transition:all .2s;user-select:none;border-radius:2px;}
.bb{background:var(--crim);color:var(--lt);border:1px solid var(--blood);}
.bb:active{background:var(--blood);}
.bg2{background:transparent;color:var(--gold);border:1px solid rgba(201,169,110,.42);}
.bg2:active{background:rgba(201,169,110,.08);}
.bs{background:rgba(255,255,255,.04);color:var(--dim);border:1px solid rgba(255,255,255,.1);}
.bs:active{background:rgba(255,255,255,.08);color:var(--lt);}
.blg{min-height:54px;font-size:.84rem;padding:14px 24px;}
.bfw{width:100%;}
.lang-btn{font-family:'Cinzel',serif;font-size:.62rem;padding:4px 10px;min-height:28px;background:rgba(201,169,110,.1);border:1px solid rgba(201,169,110,.3);color:var(--gold);cursor:pointer;border-radius:3px;letter-spacing:.1em;}
.lang-btn:active{background:rgba(201,169,110,.2);}
input[type=text],input[type=number]{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);color:var(--lt);padding:11px 13px;font-family:'Sarabun',sans-serif;font-size:1rem;outline:none;width:100%;border-radius:2px;}
input:focus{border-color:var(--gold);}
input[type=number]{max-width:72px;text-align:center;}
label{display:block;font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:.12em;color:var(--dim);margin-bottom:4px;}
.prow{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);padding:10px 13px;margin-bottom:7px;}
.pnum{font-family:'Cinzel',serif;font-size:.66rem;color:var(--dim);min-width:16px;}
.rc{padding:24px 20px;text-align:center;border:2px solid;border-radius:4px;}
.rc.murder{background:linear-gradient(150deg,#2a0808,#180406);border-color:#8b1a1a;box-shadow:0 0 32px rgba(192,32,32,.3);}
.rc.detect{background:linear-gradient(150deg,#081828,#05101a);border-color:#1a3a8b;box-shadow:0 0 28px rgba(26,58,139,.3);}
.rc.civil{background:linear-gradient(150deg,#1a1608,#100e04);border-color:rgba(201,169,110,.36);}
.rico{font-size:3rem;display:block;margin-bottom:10px;}
.rtt{font-family:'Cinzel',serif;font-size:1.7rem;font-weight:900;letter-spacing:.06em;margin-bottom:6px;}
.rc.murder .rtt{color:#ff8080;}.rc.detect .rtt{color:#88aaff;}.rc.civil .rtt{color:var(--gold);}
.rab{font-size:.83rem;margin-top:10px;padding:10px 12px;border-radius:3px;line-height:1.55;}
.rc.murder .rab{background:rgba(192,32,32,.14);color:#ffb0b0;border:1px solid rgba(192,32,32,.28);}
.rc.detect .rab{background:rgba(26,58,139,.18);color:#aac4ff;border:1px solid rgba(26,58,139,.38);}
.rc.civil .rab{background:rgba(201,169,110,.1);color:rgba(255,255,255,.5);border:1px solid rgba(201,169,110,.2);}
.ec{border-radius:8px;box-shadow:2px 3px 10px rgba(0,0,0,.55);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:transform .15s,box-shadow .15s;user-select:none;position:relative;border:1.5px solid rgba(139,26,26,.2);}
.ec:active{transform:scale(.94);}
.ec.sel{box-shadow:0 0 0 3px var(--blood),0 0 22px rgba(192,32,32,.5);}
.ec.fsel{box-shadow:0 0 0 3px #d08030,0 0 18px rgba(208,128,48,.4);}
.ec.dis{opacity:.26;pointer-events:none;}
.eg3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.pi{display:flex;align-items:center;justify-content:space-between;padding:13px 15px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);margin-bottom:6px;cursor:pointer;transition:all .18s;min-height:58px;border-radius:2px;}
.pi:active{background:rgba(255,255,255,.07);}
.pi.sel{border-color:var(--blood);background:rgba(192,32,32,.08);}
.pi.sk{border-color:#4a8a3a;background:rgba(74,138,58,.07);}
.pn{font-family:'Cinzel',serif;font-size:.9rem;}
.pj{font-size:.74rem;color:var(--dim);margin-top:2px;}
.ch{display:inline-block;font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:.1em;padding:3px 8px;border-radius:2px;}
.chr{background:rgba(139,26,26,.22);color:var(--blood);border:1px solid rgba(139,26,26,.3);}
.cho{background:rgba(42,122,74,.2);color:#5ad080;border:1px solid rgba(42,122,74,.3);}
.chb{background:rgba(26,58,139,.2);color:#88aaff;border:1px solid rgba(26,58,139,.38);}
.cx{background:rgba(201,169,110,.05);border:1px solid rgba(201,169,110,.18);padding:12px 14px;font-size:.83rem;color:var(--dim);line-height:1.6;border-radius:2px;}
.cx strong{color:var(--gold);}
.cxr{background:rgba(139,26,26,.07);border-color:rgba(139,26,26,.22);}
.cxr strong{color:var(--blood);}
.cxb{background:rgba(26,58,139,.07);border-color:rgba(26,58,139,.28);}
.cxb strong{color:#88aaff;}
.cxg{background:rgba(42,122,74,.06);border-color:rgba(42,122,74,.24);}
.cxg strong{color:#5ad080;}
.felt{background:#130606;background-image:radial-gradient(ellipse at 25% 40%,rgba(139,26,26,.13) 0%,transparent 55%),radial-gradient(ellipse at 75% 60%,rgba(139,26,26,.09) 0%,transparent 50%);border:1px solid rgba(139,26,26,.22);padding:16px;position:relative;border-radius:4px;}
.felt-l{position:absolute;top:5px;left:50%;transform:translateX(-50%);font-family:'Cinzel',serif;font-size:.5rem;letter-spacing:.32em;color:rgba(139,26,26,.32);white-space:nowrap;pointer-events:none;}
.bbar{width:100%;height:3px;background:linear-gradient(90deg,transparent,var(--blood),var(--crim),var(--blood),transparent);}
.gdiv{width:70px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:10px auto;}
.spin-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:12px 8px;text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;min-height:84px;}
.spin-icon{font-size:2.4rem;line-height:1.1;transition:transform .08s;display:block;}
.spin-name{font-family:'Cinzel',serif;font-size:.66rem;color:var(--dim);line-height:1.2;}
@keyframes glow{0%,100%{opacity:.6}50%{opacity:1}}
.spin-done .spin-icon{animation:glow .8s ease infinite;filter:drop-shadow(0 0 8px rgba(201,169,110,.6));}
.spin-done{border-color:rgba(201,169,110,.35);}
.rul h3{font-family:'Cinzel',serif;font-size:.78rem;color:var(--gold);letter-spacing:.1em;margin-bottom:8px;border-bottom:1px solid rgba(201,169,110,.2);padding-bottom:5px;}
.rul p{font-size:.84rem;color:rgba(255,255,255,.68);line-height:1.65;padding:2px 0;}
.rul span{color:var(--blood);}
.death-panel{background:linear-gradient(150deg,#200a0a,#0d0408);border:2px solid var(--blood);border-radius:8px;padding:28px 20px;text-align:center;box-shadow:0 0 40px rgba(192,32,32,.25);}
@keyframes faIn{from{opacity:0}to{opacity:1}}
@keyframes faUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes scIn{from{opacity:0;transform:scale(.9)}to{opacity:1;transform:scale(1)}}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-6px)}40%{transform:translateX(6px)}60%{transform:translateX(-4px)}80%{transform:translateX(4px)}}
.afd{animation:faIn .45s ease forwards;}
.afu{animation:faUp .45s ease forwards;}
.asc{animation:scIn .4s ease forwards;}
.ashake{animation:shake .4s ease forwards;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--crim);border-radius:2px;}
</style>
</head>
