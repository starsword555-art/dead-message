/* ══ SPIN ANIMATION ══ */
function doSpin(f,max){
  if(!document.getElementById('spinr0'))return;
  const ic=['🔪','🔍','👤','⚔️','🎭','🃏'];
  G.players.forEach((_,i)=>{
    const el=document.getElementById('spinr'+i);
    if(!el)return;
    if(f<max){el.textContent=ic[Math.floor(Math.random()*4)];el.style.transform='scale('+(0.88+Math.random()*.24)+')';}
  });
  const msg=document.getElementById('spinMsg');
  if(msg)msg.textContent=f<max*.35?t('sp1'):f<max*.7?t('sp2'):t('spDone');
  if(f%3===0&&f<max)snd('tick');
  if(f<max){
    const d=f<14?65:f<22?120:f<30?190:280;
    setTimeout(()=>doSpin(f+1,max),d);
  } else {
    snd('settle');
    G.players.forEach((_,i)=>{
      const el=document.getElementById('spinr'+i),card=document.getElementById('sc'+i);
      if(el){el.textContent='❓';el.style.transform='scale(1)';}
      if(card)card.classList.add('spin-done');
    });
    if(msg)msg.textContent=t('spMsg');
    const btn=document.getElementById('spinBtn');
    if(btn){btn.style.opacity='1';btn.style.pointerEvents='auto';}
  }
}

/* ══ AFTER RENDER ══ */
function afterRender(){
  if(G.screen==='title'){
    setTimeout(()=>{document.getElementById('cL')?.classList.add('op');document.getElementById('cR')?.classList.add('op');},100);
    setTimeout(()=>snd('dawn'),800);
  }
  if(G.screen==='role-spin') setTimeout(()=>doSpin(0,34),400);
  if(G.screen==='death-reveal') snd('death');
  if(G.screen==='dawn') snd('dawn');
  if(G.screen==='gameover') setTimeout(()=>snd(G.gameResult==='town'?'winCitizen':'winMurderer'),300);
  if(G.screen==='donate') snd('settle');
}

/* ══ EVENTS ══ */
document.addEventListener('click',ev=>{
  const btn=ev.target.closest('[data-a]');if(!btn)return;
  const a=btn.dataset.a,v=btn.dataset.v;
  if(a==='toggle-lang'){G.lang=G.lang==='th'?'en':'th';snd('click');render();return;}
  if(a==='go-rules'){G.screen='rules';snd('click');render();return;}
  if(a==='go-setup'){G.screen='setup';if(!G.players.length)G.players=[];snd('click');render();return;}
  if(a==='go-title'){G.screen='title';snd('click');render();return;}
  if(a==='go-donate'){snd('click');go('donate');return;}
  if(a==='upd-p'){
    const n=Math.max(3,Math.min(10,parseInt(document.getElementById('pcount').value)||4));
    const div=document.getElementById('prowsDiv');
    const names=Array.from(div.querySelectorAll('input[type=text]')).map(el=>el.value);
    G.players=Array.from({length:n},(_,i)=>({name:names[i]||G.players[i]?.name||'',role:'',alive:true}));
    document.getElementById('pcount').value=n;
    div.innerHTML=Array.from({length:n},(_,i)=>'<div class="prow"><span class="pnum">'+(i+1)+'</span><input type="text" placeholder="'+(G.lang==='en'?'Player '+(i+1):'ชื่อผู้เล่น '+(i+1))+'" id="pn'+i+'" value="'+e(G.players[i]?.name||'')+'"></div>').join('');
    return;
  }
  if(a==='start-game'){initGame();return;}
  if(a==='go-role-show'){G.screen='role-show';G.roleStep=0;G.roleRevealed=false;snd('click');render();return;}
  if(a==='role-rev'){G.roleRevealed=true;snd('roleReveal');render();return;}
  if(a==='role-next'){G.roleStep++;G.roleRevealed=false;snd('click');if(G.roleStep>=G.players.length)go('all-awake');else render();return;}
  if(a==='start-night'){snd('night');initNight();go('night');return;}
  if(a==='nrev'){G.nightRevealed=true;render();return;}
  if(a==='np'){G.nightPick=parseInt(v);render();return;}
  if(a==='np-fk'){
    const i=parseInt(v);
    if(G.nightFakePick.includes(i))G.nightFakePick=G.nightFakePick.filter(x=>x!==i);
    else if(G.nightFakePick.length<2)G.nightFakePick.push(i);
    render();return;
  }
  if(a==='nok'){
    const s=G.nightStep;
    if(s===0){G.victimIdx=G.nightPick;snd('stab');}
    else if(s===1)G.realEv=G.nightPick;
    else if(s===3)G.fakeEvs=[...G.nightFakePick];
    G.nightPick=-1;G.nightFakePick=[];
    nightAdvance();return;
  }
  if(a==='after-death'){
    if(G.deathRevealCtx==='night'){
      if(killerWins()){G.gameResult='murderer';go('gameover');}
      else go('dawn');
    } else {
      if(G.deathRevealIdx===G.murdererIdx){G.gameResult='town';go('gameover');}
      else if(killerWins()){G.gameResult='murderer';go('gameover');}
      else{G.round++;initNight();go('night');}
    }
    return;
  }
  if(a==='go-vote'){G.voteTarget=undefined;snd('click');go('vote');return;}
  if(a==='vpick'){G.voteTarget=parseInt(v);render();return;}
  if(a==='vskip'){G.voteTarget=-99;render();return;}
  if(a==='vconf'){
    const skip=G.voteTarget===-99;
    if(!skip){
      snd('execute');
      G.players[G.voteTarget].alive=false;
      G.deathRevealIdx=G.voteTarget;
      G.deathRevealCtx='execution';
      go('death-reveal');return;
    }
    if(killerWins()){G.gameResult='murderer';go('gameover');return;}
    G.round++;initNight();go('night');return;
  }
});
render();
</script>
