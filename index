function initGame(){
  const cnt=Math.max(3,Math.min(10,parseInt(document.getElementById('pcount')?.value)||4));
  const names=Array.from({length:cnt},(_,i)=>{const el=document.getElementById('pn'+i);return(el&&el.value.trim())||'Player '+(i+1);});
  const idxs=shuf(Array.from({length:cnt},(_,i)=>i));
  G.murdererIdx=idxs[0];G.detectiveIdx=idxs[1];
  G.players=names.map((name,i)=>({name,role:i===G.murdererIdx?'murderer':i===G.detectiveIdx?'detective':'citizen',alive:true}));
  G.round=1;G.history=[];G.roleStep=0;G.roleRevealed=false;
  snd('click');go('role-spin');
}
function initNight(){
  G.roundEvids=shuf(Array.from({length:EVID.length},(_,i)=>i)).slice(0,9);
  G.victimIdx=-1;G.realEv=-1;G.fakeEvs=[];
  G.nightStep=0;G.nightRevealed=false;G.nightPick=-1;G.nightFakePick=[];G.shownCards=[];
}
function nightAdvance(){
  G.nightStep++;G.nightRevealed=false;G.nightPick=-1;G.nightFakePick=[];
  if(G.nightStep===2){
    if(!G.players[G.detectiveIdx].alive||G.detectiveIdx===G.victimIdx)G.nightStep=3;
  }
  if(G.nightStep===4){
    G.players[G.victimIdx].alive=false;
    G.shownCards=shuf([G.realEv,...G.fakeEvs]);
    G.history.push({victimName:G.players[G.victimIdx].name,victimRole:G.players[G.victimIdx].role,shownCards:[...G.shownCards],realEv:G.realEv,round:G.round});
    G.deathRevealIdx=G.victimIdx;G.deathRevealCtx='night';
    go('death-reveal');
  } else render();
}

